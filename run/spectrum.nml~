T2max=34.25993294742506
/

&SF_PARAMS
T2_star=34.25993294742506
g_star=1 !isothermal
n_star=1d20
/

!&TURB_PARAMS
!turb=.true.
!turb_type=1         ! 1=forced evolving, 2=forced fixed, 3=decaying
!turb_seed=42         ! -1 = random
!comp_frac=0.5       ! compressive fraction
