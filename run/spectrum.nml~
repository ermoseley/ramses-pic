/

&AMR_PARAMS
levelmin=5
levelmax=6
ngridmax=20000!1000000
npartmax=20000
boxlen=1
/
&REFINE_PARAMS
/

&HYDRO_PARAMS
gamma=1.66666667
courant_factor=0.8
scheme='muscl'
slope_type=1
riemann='hlld'
riemann2d='hlld'
pressure_fix=.true.
beta_fix=0.5
dens_llf=3d-2
/

&INIT_PARAMS
filetype='grafic'
initfile(1)='/Users/moseley/ramses-pic/run/ic_dturb/ic_dturb_5'
!nregion=1
!region_type='square'
!x_center=0.5
!y_center=0.5
!z_center=0.5
!length_x=1
!length_y=1
!length_z=1
