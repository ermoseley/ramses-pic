!forcing_power_spectrum='parabolic' !power_law, parabolic, konstandin, test
!turb_T=0.33 ! 0.29241000937376255
!turb_Ndt=10       ! Number of timesteps per autocorr. time
!turb_rms=20      ! rms turbulent forcing acceleration
