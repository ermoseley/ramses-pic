!ibound_min=-1,1
!ibound_max=-1,1
!jbound_min=0,0
!jbound_max=0,0
!bound_type=3,1
!d_bound=3.0
!u_bound=2.0
!C_bound=3.0
/

&OUTPUT_PARAMS
!delta_tout=0.25 ! first output had 0.05
!foutput=25000
!noutput=6
tout=0.01
tend=0.01
!walltime_hrs=24.0 ! job submission allocated time
!minutes_dump=10.0 ! minutes before to print an output
/

&UNITS_PARAMS
units_density=7.0d-23
units_time=1.1563d15
