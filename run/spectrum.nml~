! This is the RAMSES parameter file for the dust driven turbulence.

&RUN_PARAMS
hydro=.true.
verbose=.false.
pic=.true.
tracer=.true.
ncontrol=1
nrestart=0
nremap=10
/

&GRAIN_PARAMS
pic_dust=.true.
back_reaction=.true.
size_bins=.false.
lognormal=.false.
astrodust=.true.
mrn_spectrum=.false.
universal_drag=.false.
mhd_pic_loadf=2.0d0
gyrofactor=0.05
constant_t_stop=.false.
ddex = 1.0
ndust=0
charge_slope=-2.0
du_charge_to_mass=200 !0.9 micron grain !234.0 ! 1.0 micron
!t_stop=0.1
